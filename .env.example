# k-parent-skill — 환경변수 템플릿
# 사용법: cp .env.example .env 후 값을 채우세요. (.env 는 .gitignore 로 커밋되지 않음)
# 키 발급 안내와 라이브 fixture 재생성 명령은 OWNER-TASKS.md 참고.

# --- 학교/영양 (NEIS 교육정보 개방포털: https://open.neis.go.kr) ---
KEDU_INFO_KEY=

# --- 공공데이터포털 통합키 (https://www.data.go.kr) ---
# 놀이시설/도시공원, 어린이집/유치원, 응급의료(e-gen) 서비스에 공용. 서비스별 활용신청 필요.
KSKILL_DATAGOKR_KEY=

# --- 한국관광공사 TourAPI 4.0 (놀이/축제/여행) ---
KSKILL_TOURAPI_KEY=

# --- 서울 열린데이터광장 (공공서비스예약: https://data.seoul.go.kr) ---
KSKILL_SEOUL_KEY=

# --- 도서관 정보나루 (https://data4library.kr/apiUtilization) ---
KSKILL_LIBRARY_KEY=

# --- 문화포털 공연/전시 (https://www.culture.go.kr) ---
KSKILL_CULTURE_KEY=

# --- 네이버 검색/쇼핑 API (https://developers.naver.com) ---
KSKILL_NAVER_CLIENT_ID=
KSKILL_NAVER_CLIENT_SECRET=

# --- 쿠팡 파트너스 (어필리에이트, 보조 수익: https://partners.coupang.com) ---
KSKILL_COUPANG_ACCESS_KEY=
KSKILL_COUPANG_SECRET_KEY=

# --- YouTube Data API v3 (Google Cloud Console) ---
KSKILL_YOUTUBE_KEY=
